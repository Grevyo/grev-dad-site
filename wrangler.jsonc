{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "grev-dad-site",
  "main": "src/index.js",
  "compatibility_date": "2026-03-20",
  "assets": {
    "directory": "./public"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "grev-dad-db",
      "database_id": "PASTE_YOUR_DATABASE_ID_HERE"
    }
  ]
}