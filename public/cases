  <div class="wrap">
    <div class="box">
      <h1>CS2 Case Simulator</h1>
      <p>Test your luck on the Kilowatt Case!</p>

      <div class="spinner-viewport">
        <div class="center-line"></div>
        <div id="rail" class="items-rail">
            </div>
      </div>

      <button id="openBtn" class="btn-open" onclick="startSpin()">Open Case</button>
      <div id="win-message"></div>
    </div>
  </div>

  <script src="/header.js"></script>
